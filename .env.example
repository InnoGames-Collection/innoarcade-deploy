# Copy this file to `.env` and fill in your Supabase project values.
# Both of these are PUBLIC (safe to commit/share) — security comes from
# Row-Level Security, not from hiding these. Find them in your Supabase project:
#   Settings → API → Project URL  and  Project API keys → anon public
#
# NEVER put the `service_role` key here or anywhere in the frontend — it bypasses
# RLS. It only goes into the Edge Function's secrets (see supabase/README.md).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJ...your-anon-public-key...

# ---------------------------------------------------------------------------
# Payments / economy — these are EDGE FUNCTION SECRETS, NOT frontend vars.
# Do NOT prefix them with VITE_ and do NOT put them in this committed file with
# real values. Set them with `supabase secrets set …` (see supabase/README.md).
# Until TELEBIRR_APP_KEY is set, buy-coins runs in SANDBOX and credits instantly,
# so the coin store + paid tournaments work with no merchant account.
# ---------------------------------------------------------------------------
# The economy is 100% server-sourced: coins, points, gold, orders, tournament
# entries, leaderboards and subscriptions all live in Supabase (no localStorage,
# no offline/local economy). The app therefore REQUIRES the VITE_SUPABASE_* keys
# above and the Edge Functions deployed — there is no demo/local fallback.

# DEMO ONLY frontend var. With no SMS gateway, the send-sms hook (mock mode)
# writes each OTP to the public dev_otps table; set this true to show the code on
# the sign-in screen so any phone can sign in without real SMS. Remove/false for
# production (and drop dev_otps). Requires supabase/dev.sql applied.
# VITE_DEV_OTP_ECHO=true

# TELEBIRR_APP_KEY=...            # TeleBirr merchant app key (enables real checkout)
# TELEBIRR_APP_ID=...             # TeleBirr merchant appId / short code
# TELEBIRR_PUBLIC_KEY=...         # TeleBirr public key for notification signing
# TELEBIRR_CHECKOUT_URL=...       # hosted-payment base URL
# CRON_SECRET=...                 # shared secret for the settle-tournament cron job

# ---------------------------------------------------------------------------
# Partner subscription portal — EDGE FUNCTION SECRETS only
# Contract: partner-mt-and-webhooks.openapi.yaml
# (see docs/SUBSCRIPTION_PORTAL_PROGRESS.md). Set via:
#   supabase secrets set KEY=value
# ---------------------------------------------------------------------------
# PORTAL_ENABLED=true
# PORTAL_BASE_URL=http://168.119.53.26:8484
# PORTAL_API_KEY=…                      # X-API-Key for POST /api/v1/mt/send
# PORTAL_WEBHOOK_SECRET=…               # HMAC secret for subscription notify
# PORTAL_WEBHOOK_SKIP_VERIFY=true       # local/sandbox only — never in prod
# PORTAL_WEBHOOK_MAX_SKEW_SEC=300
# PORTAL_MT_SEND_PATH=/api/v1/mt/send
# PORTAL_MT_CALLBACK_URL={SUPABASE_URL}/functions/v1/portal-sms-dlr
# PORTAL_MT_CALLBACK_TOKEN=…            # optional guard for unsigned MT callbacks
# PORTAL_SERVICE_DAILY=…
# PORTAL_SERVICE_WEEKLY=…
# PORTAL_SERVICE_MONTHLY=…
# PORTAL_DEFAULT_SERVICE_ID=…           # fallback for OTP MT if needed
# PORTAL_SHORTCODE_HINT=…               # shown in pending / cancel / login-denied messages
# PORTAL_LOGIN_ALLOWLIST=+2519…,+2519…  # ops phones that may OTP without a sub
# PORTAL_SEND_WELCOME=false             # optional MT type=optin after subscription notify
# PORTAL_GAME_URL=https://…             # used in default welcome copy
# PORTAL_WELCOME_MESSAGE=…              # override welcome SMS text
# SMS_MODE=portal                       # mock | gateway | portal
# Login gate (pre-OTP): {SUPABASE_URL}/functions/v1/portal-login-gate
# Staging webhooks:
#   {SUPABASE_URL}/functions/v1/portal-subscription-webhook   ← notify URL
#   {SUPABASE_URL}/functions/v1/portal-sms-dlr                ← MT callbackUrl
#   {SUPABASE_URL}/functions/v1/portal-payment-webhook        ← dormant
