    "sprites:compress": "node scripts/compress-runner-sprites.mjs",
    "skins:ethio-f": "node scripts/process-ethio-f-skins.mjs && node scripts/compress-runner-sprites.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.78.0"
  }
}
