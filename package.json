{
  "name": "innoarcade",
  "version": "0.1.0",
  "description": "GoPlay — free HTML5 arcade games",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "seed": "node supabase/seed.mjs",
    "setup:test-phones": "node supabase/push-test-phones.mjs",
    "verify:auth": "node supabase/verify-auth-setup.mjs",
    "sprites:compress": "node scripts/compress-runner-sprites.mjs",
    "skins:ethio-f": "node scripts/process-ethio-f-skins.mjs && node scripts/compress-runner-sprites.mjs",
    "covers:generate": "node scripts/generate-covers.mjs",
    "covers:import": "node scripts/import-cover.mjs",
    "covers:import-all": "node scripts/import-all-covers.mjs",
    "lint:games": "node scripts/lint-game-shell.mjs",
    "icons:validate": "node scripts/validate-memory-match-icons.mjs",
    "icons:process": "node scripts/process-memory-match-icons.mjs",
    "icons:deploy": "node scripts/process-memory-match-icons.mjs --deploy"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "typescript": "~5.6.2",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.78.0",
    "@types/three": "^0.185.1",
    "three": "^0.185.1"
  }
}
